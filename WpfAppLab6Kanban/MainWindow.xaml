<Window x:Class="WpfAppLab6Kanban.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Modern Kanban Board" Height="750" Width="1200"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <!--
            Task Card DataTemplate
            ======================
            Topic 1 — Command bindings replace Click event handlers.
            Topic 2 — Toolkit-generated command names (MoveLeftCommand, etc.).
            Topic 4 — Shared styles from App.xaml replace all inline values:
                       CardArrowButton  → ←/→ buttons
                       AccentBrush      → priority badge colour
                       CardBackgroundBrush, TextBrush, SecondaryTextBrush → tokens
        -->
        <DataTemplate x:Key="TaskTemplate">
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Margin="0,0,0,12"
                    Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Title + priority badge -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap"/>
                        <!-- Badge background pill -->
                        <Border Grid.Column="1"
                                Padding="6,2" CornerRadius="4"
                                Background="{StaticResource AccentBrush}"
                                VerticalAlignment="Top" Margin="10,0,0,0" Opacity="0.1"
                                Visibility="{Binding DataContext.BadgeVisibility,
                                             RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <!-- Badge text -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Priority}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Top" Margin="16,2,6,2"
                                   Visibility="{Binding DataContext.BadgeVisibility,
                                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>

                    <TextBlock Text="{Binding Description}"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               MaxHeight="60" TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,12"/>

                    <Separator Background="#F0F0F0" Margin="0,0,0,10" Opacity="0.5"/>

                    <!-- Card action row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Move arrows — use shared CardArrowButton style from App.xaml -->
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Button Content="←"
                                    Style="{StaticResource CardArrowButton}"
                                    Margin="0,0,5,0"
                                    Command="{Binding DataContext.MoveLeftCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="→"
                                    Style="{StaticResource CardArrowButton}"
                                    Command="{Binding DataContext.MoveRightCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>

                        <!-- Delete -->
                        <Button Grid.Column="1" Content="Delete"
                                Background="Transparent"
                                Foreground="{StaticResource DangerBrush}"
                                FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding DataContext.DeleteTaskCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ListBox defaults — applies to all three column listboxes -->
        <Style TargetType="ListBox">
            <Setter Property="Background"                               Value="Transparent"/>
            <Setter Property="BorderThickness"                          Value="0"/>
            <Setter Property="ItemTemplate"                             Value="{StaticResource TaskTemplate}"/>
            <Setter Property="HorizontalContentAlignment"               Value="Stretch"/>
            <Setter Property="Padding"                                  Value="5"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header Bar ─────────────────────────────────────────── -->
        <Border Background="{DynamicResource HeaderBackgroundBrush}" Padding="25,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1" Direction="270"/>
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Kanban" FontSize="26" FontWeight="ExtraBold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Board"  FontSize="26" FontWeight="Light"
                               Foreground="{DynamicResource TextBrush}" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!--
                        ModernPillButton is now defined in App.xaml (Topic 4).
                        Previously it was duplicated inside MainWindow.xaml.Resources.
                    -->
                    <Button Content="+ New Task"
                            Style="{StaticResource ModernPillButton}"
                            Command="{Binding AddTaskCommand}"
                            Margin="0,0,15,0"/>

                    <!-- Hamburger — Click stays in code-behind (UI mechanic only) -->
                    <Button x:Name="HamburgerButton" Width="40" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="HamburgerButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="View Archives"
                                          Command="{Binding ViewArchivesCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="📁" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="End Sprint (Archive All)"
                                          Command="{Binding ArchiveAllCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🧹" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Help &amp; Documentation"
                                          Command="{Binding OpenHelpCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="❓" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Settings"
                                          Command="{Binding OpenSettingsCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="⚙️" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="≡" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,-4,0,0"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Board columns ──────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TO DO — uses design-token brush TodoBrush from App.xaml -->
            <Border Grid.Column="0" Margin="8"
                    BorderBrush="{StaticResource TodoBrush}" BorderThickness="2.5"
                    Background="#122196F3" CornerRadius="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="TO DO" FontWeight="Black" FontSize="13"
                               Foreground="{StaticResource TodoBrush}"
                               HorizontalAlignment="Center" Margin="0,15,0,10"/>
                    <ListBox Grid.Row="1" x:Name="TodoListBox"
                             ItemsSource="{Binding TodoTasks}"
                             MouseDoubleClick="ListBox_MouseDoubleClick"/>
                </Grid>
            </Border>

            <!-- IN PROGRESS -->
            <Border Grid.Column="1" Margin="8"
                    BorderBrush="{StaticResource InProgressBrush}" BorderThickness="2.5"
                    Background="#12FF9800" CornerRadius="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="IN PROGRESS" FontWeight="Black" FontSize="13"
                               Foreground="{StaticResource InProgressBrush}"
                               HorizontalAlignment="Center" Margin="0,15,0,10"/>
                    <ListBox Grid.Row="1" x:Name="InProgressListBox"
                             ItemsSource="{Binding InProgressTasks}"
                             MouseDoubleClick="ListBox_MouseDoubleClick"/>
                </Grid>
            </Border>

            <!-- DONE -->
            <Border Grid.Column="2" Margin="8"
                    BorderBrush="{StaticResource DoneBrush}" BorderThickness="2.5"
                    Background="#124CAF50" CornerRadius="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="DONE" FontWeight="Black" FontSize="13"
                               Foreground="{StaticResource DoneBrush}"
                               HorizontalAlignment="Center" Margin="0,15,0,10"/>
                    <ListBox Grid.Row="1" x:Name="DoneListBox"
                             ItemsSource="{Binding DoneTasks}"
                             MouseDoubleClick="ListBox_MouseDoubleClick"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
