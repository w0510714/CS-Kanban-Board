<Window x:Class="WpfAppLab6Kanban.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WpfAppLab6Kanban.Controls"
        mc:Ignorable="d"
        Title="Modern Kanban Board" Height="750" Width="1200"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <!-- Task Card DataTemplate: buttons bind to ViewModel commands via RelativeSource -->
        <DataTemplate x:Key="TaskTemplate">
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Margin="0,0,0,12"
                    Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Title + priority badge -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap"/>
                        <!-- Badge pill background -->
                        <Border Grid.Column="1"
                                Padding="6,2" CornerRadius="4"
                                Background="{StaticResource AccentBrush}"
                                VerticalAlignment="Top" Margin="10,0,0,0" Opacity="0.1"
                                Visibility="{Binding DataContext.BadgeVisibility,
                                             RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <!-- Badge label -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Priority}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Top" Margin="16,2,6,2"
                                   Visibility="{Binding DataContext.BadgeVisibility,
                                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>

                    <TextBlock Text="{Binding Description}"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               MaxHeight="60" TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,12"/>

                    <Separator Background="#F0F0F0" Margin="0,0,0,10" Opacity="0.5"/>

                    <!-- Card action row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Move arrows -->
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Button Content="←"
                                    Style="{StaticResource CardArrowButton}"
                                    Margin="0,0,5,0"
                                    Command="{Binding DataContext.MoveLeftCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="→"
                                    Style="{StaticResource CardArrowButton}"
                                    Command="{Binding DataContext.MoveRightCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>

                        <!-- Delete -->
                        <Button Grid.Column="1" Content="Delete"
                                Background="Transparent"
                                Foreground="{StaticResource DangerBrush}"
                                FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding DataContext.DeleteTaskCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
        <Style TargetType="ListBox">
            <Setter Property="Background"                                   Value="Transparent"/>
            <Setter Property="BorderThickness"                              Value="0"/>
            <Setter Property="ItemTemplate"                                 Value="{StaticResource TaskTemplate}"/>
            <Setter Property="HorizontalContentAlignment"                   Value="Stretch"/>
            <Setter Property="Padding"                                      Value="5"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"   Value="Disabled"/>
            <Setter Property="ScrollViewer.CanContentScroll"                Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing"             Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode"         Value="Recycling"/>
            <Setter Property="VirtualizingPanel.ScrollUnit"                 Value="Item"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Background="{DynamicResource HeaderBackgroundBrush}" Padding="25,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1" Direction="270"/>
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Kanban" FontSize="26" FontWeight="ExtraBold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Board"  FontSize="26" FontWeight="Light"
                               Foreground="{DynamicResource TextBrush}" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- "+ New Task" binds to AddTaskCommand on the ViewModel -->
                    <Button Content="+ New Task"
                            Style="{StaticResource ModernPillButton}"
                            Command="{Binding AddTaskCommand}"
                            Margin="0,0,15,0"/>

                    <!-- Hamburger — Click opens the ContextMenu (UI-only, handled in code-behind) -->
                    <Button x:Name="HamburgerButton" Width="40" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="HamburgerButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="View Archives" Click="Menu_ViewArchives_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="📁" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="End Sprint (Archive All)" Click="Menu_ArchiveAll_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🧹" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Help &amp; Documentation" Click="Menu_OpenHelp_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="❓" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Settings" Click="Menu_OpenSettings_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="⚙️" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="≡" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,-4,0,0"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Board columns — each KanbanColumnControl is a reusable UserControl -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:KanbanColumnControl
                Grid.Column="0"
                ColumnTitle="TO DO"
                ColumnColor="{StaticResource TodoBrush}"
                ColumnBackground="#122196F3"
                TasksSource="{Binding TodoTasks}"
                ItemDoubleClickCommand="{Binding EditTaskCommand}"/>

            <controls:KanbanColumnControl
                Grid.Column="1"
                ColumnTitle="IN PROGRESS"
                ColumnColor="{StaticResource InProgressBrush}"
                ColumnBackground="#12FF9800"
                TasksSource="{Binding InProgressTasks}"
                ItemDoubleClickCommand="{Binding EditTaskCommand}"/>

            <controls:KanbanColumnControl
                Grid.Column="2"
                ColumnTitle="DONE"
                ColumnColor="{StaticResource DoneBrush}"
                ColumnBackground="#124CAF50"
                TasksSource="{Binding DoneTasks}"
                ItemDoubleClickCommand="{Binding EditTaskCommand}"/>
        </Grid>
    </Grid>
</Window>
