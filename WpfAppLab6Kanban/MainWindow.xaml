<Window x:Class="WpfAppLab6Kanban.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppLab6Kanban"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <!-- Style for the Task Cards within the ListBox -->
        <DataTemplate x:Key="TaskTemplate">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Background="White" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#666" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Button Content="←" Click="MoveLeft_Click" Margin="0,0,5,0" Padding="5,0"/>
                        <Button Content="→" Click="MoveRight_Click" Margin="0,0,5,0" Padding="5,0"/>
                        <Button Content="Delete" Click="DeleteTask_Click" Background="#FFEAEA" Foreground="#D32F2F" Padding="5,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#F4F4F9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemTemplate" Value="{StaticResource TaskTemplate}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Background="#E0E0E0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Background="White" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Kanban Board" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="+ Add New Task" Padding="10,5" Click="AddTask_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- To Do Column -->
            <StackPanel Grid.Column="0" Margin="5">
                <Border Background="#2196F3" CornerRadius="5,5,0,0" Padding="10">
                    <TextBlock Text="TO DO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <ListBox x:Name="TodoListBox" ItemsSource="{Binding TodoTasks}" MouseDoubleClick="ListBox_MouseDoubleClick"/>
            </StackPanel>

            <!-- In Progress Column -->
            <StackPanel Grid.Column="1" Margin="5">
                <Border Background="#FF9800" CornerRadius="5,5,0,0" Padding="10">
                    <TextBlock Text="IN PROGRESS" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <ListBox x:Name="InProgressListBox" ItemsSource="{Binding InProgressTasks}" MouseDoubleClick="ListBox_MouseDoubleClick"/>
            </StackPanel>

            <!-- Done Column -->
            <StackPanel Grid.Column="2" Margin="5">
                <Border Background="#4CAF50" CornerRadius="5,5,0,0" Padding="10">
                    <TextBlock Text="DONE" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <ListBox x:Name="DoneListBox" ItemsSource="{Binding DoneTasks}" MouseDoubleClick="ListBox_MouseDoubleClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
