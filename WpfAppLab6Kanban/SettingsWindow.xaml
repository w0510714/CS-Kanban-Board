<Window x:Class="WpfAppLab6Kanban.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Settings" Height="400" Width="450" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="25" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Settings &amp; Personalization" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource TextBrush}"/>
            
            <StackPanel Grid.Row="1">
                <TextBlock Text="Themes" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                    <DockPanel>
                        <TextBlock Text="Dark Mode" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        <CheckBox x:Name="DarkModeToggle" HorizontalAlignment="Right" Click="DarkModeToggle_Click" VerticalAlignment="Center">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </DockPanel>
                </Border>

                <TextBlock Text="Visuals" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="15">
                    <DockPanel>
                        <TextBlock Text="Show Priority Badges" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        <CheckBox x:Name="BadgesToggle" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </DockPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save &amp; Apply" Click="Save_Click" Width="120" Height="35" Margin="0,0,10,0" Background="#1A73E8" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="17"/></Style></Button.Resources>
                </Button>
                <Button Content="Cancel" Click="Close_Click" Width="90" Height="35" Background="#DDD" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="17"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
