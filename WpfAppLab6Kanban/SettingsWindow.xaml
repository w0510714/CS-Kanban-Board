<Window x:Class="WpfAppLab6Kanban.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Settings" Height="380" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Settings &amp; Personalization"
                       Style="{StaticResource DialogTitle}"/>

            <StackPanel Grid.Row="1">

                <!-- Themes section -->
                <TextBlock Text="Themes" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SettingsCard}">
                    <DockPanel>
                        <TextBlock Text="Dark Mode"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{StaticResource TextBrush}"/>
                        <CheckBox x:Name="DarkModeToggle"
                                  Style="{StaticResource SettingsToggle}"
                                  Click="DarkModeToggle_Click"/>
                    </DockPanel>
                </Border>

                <!-- Visuals section -->
                <TextBlock Text="Visuals" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SettingsCard}">
                    <DockPanel>
                        <TextBlock Text="Show Priority Badges"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{StaticResource TextBrush}"/>
                        <CheckBox x:Name="BadgesToggle"
                                  Style="{StaticResource SettingsToggle}"/>
                    </DockPanel>
                </Border>

            </StackPanel>

            <!-- Footer buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save &amp; Apply"
                        Width="130"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="Cancel"
                        Width="90"
                        Style="{StaticResource MutedButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
