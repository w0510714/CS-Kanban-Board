<Window x:Class="WpfAppLab6Kanban.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="25" Background="{DynamicResource WindowBackgroundBrush}">
        <StackPanel>
            <TextBlock Text="App Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource TextBrush}"/>
            
            <DockPanel Margin="0,0,0,20">
                <TextBlock Text="Dark Mode" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                <CheckBox x:Name="DarkModeToggle" HorizontalAlignment="Right" Click="DarkModeToggle_Click" VerticalAlignment="Center">
                    <CheckBox.LayoutTransform>
                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                    </CheckBox.LayoutTransform>
                </CheckBox>
            </DockPanel>

            <TextBlock Text="Interface" FontWeight="Bold" Margin="0,10,0,5" Foreground="{DynamicResource TextBrush}"/>
            <CheckBox Content="Show high priority badges" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,5"/>

            <Button Content="Close" Click="Close_Click" Width="80" Height="30" HorizontalAlignment="Right" Margin="0,40,0,0" Background="#DDD" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>
