<Window x:Class="WpfAppLab6Kanban.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WpfAppLab6Kanban.Controls"
        Title="System Settings" Height="380" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Settings &amp; Personalization"
                       Style="{StaticResource DialogTitle}"/>
            <StackPanel Grid.Row="1">
                <TextBlock Text="Themes" Style="{StaticResource SectionHeader}"/>
                <controls:SettingsToggleRow x:Name="DarkModeRow"
                                            Label="Dark Mode"
                                            Toggled="DarkModeRow_Toggled"/>

                <TextBlock Text="Visuals" Style="{StaticResource SectionHeader}"/>
                <controls:SettingsToggleRow x:Name="BadgesRow"
                                            Label="Show Priority Badges"/>
            </StackPanel>

            <!-- Footer buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save &amp; Apply"
                        Width="130"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="Cancel"
                        Width="90"
                        Style="{StaticResource MutedButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
