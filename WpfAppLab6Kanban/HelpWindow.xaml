<Window x:Class="WpfAppLab6Kanban.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help &amp; Documentation" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Branding header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Kanban Mastery"
                           FontSize="26" FontWeight="ExtraBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="User Guide &amp; Professional Tips"
                           FontSize="14"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="CORE INTERACTIONS"
                               Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="• Task Intelligence"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,0,0,12"
                                       Text="Double-click any task card to access the Detail Workspace. Here you can refine descriptions, adjust priorities, or safely retire tasks."/>
                            <TextBlock Text="• Agile Transitions"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Utilize the directional arrows on each card to facilitate rapid movement across the 'To Do', 'In Progress', and 'Done' states."/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="WORKFLOW MANAGEMENT"
                               Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="• Sprint Completion"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,0,0,12"
                                       Text="Select 'End Sprint' from the main menu to archive all active tasks. This effectively resets your board for the next cycle while preserving history."/>
                            <TextBlock Text="• Archive Retrieval"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Accidentally moved a task? Open 'View Archives' from the menu to see your complete archive history and permanently manage older entries."/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="TIPS &amp; TRICKS"
                               Style="{StaticResource SectionHeader}"/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,5"
                               Text="• Keyboard shortcut: Use 'Enter' in pop-ups to quickly save your changes."/>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,20"
                               Text="• Focus Mode: Enable Dark Mode in settings for a distraction-free high-contrast experience."/>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Button Grid.Row="2"
                    Content="Got it!"
                    Width="100"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
