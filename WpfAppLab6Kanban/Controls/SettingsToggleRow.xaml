<UserControl x:Class="WpfAppLab6Kanban.Controls.SettingsToggleRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource SettingsCard}">
        <DockPanel>
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       VerticalAlignment="Center"
                       FontSize="15"
                       Foreground="{DynamicResource TextBrush}"/>
            <CheckBox x:Name="InnerCheckBox"
                      Style="{StaticResource SettingsToggle}"
                      Checked="CheckBox_Changed"
                      Unchecked="CheckBox_Changed"/>
        </DockPanel>
    </Border>
</UserControl>
