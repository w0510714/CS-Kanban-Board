<Window x:Class="WpfAppLab6Kanban.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Task" Height="500" Width="550" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="25" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Task Title" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox" Grid.Row="1" Margin="0,0,0,15" Padding="8" FontSize="14" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="#DDD"/>

            <TextBlock Grid.Row="2" Text="Priority" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="PriorityComboBox" Grid.Row="3" Margin="0,0,0,15" Padding="5" SelectedIndex="1">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <TextBlock Grid.Row="4" Text="Description (Optional)" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Row="5" Margin="0,0,0,20" Height="150" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="#DDD"/>

            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Create Task" Width="120" Height="35" Margin="0,0,10,0" Click="CreateButton_Click" IsDefault="True" Background="#1A73E8" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="18"/></Style>
                    </Button.Resources>
                </Button>
                <Button Content="Cancel" Width="90" Height="35" Click="CancelButton_Click" IsCancel="True" Background="#DDD" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="18"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
