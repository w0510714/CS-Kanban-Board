<Window x:Class="WpfAppLab6Kanban.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Task" Height="460" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title field -->
            <TextBlock Text="Task Title" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="TitleTextBox"
                     Grid.Row="1"
                     Style="{StaticResource FormTextBox}"/>

            <!-- Priority field -->
            <TextBlock Grid.Row="2" Text="Priority"
                       Style="{StaticResource FormLabel}"/>
            <ComboBox x:Name="PriorityComboBox"
                      Grid.Row="3"
                      Style="{StaticResource FormComboBox}"
                      SelectedIndex="1">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <!-- Description field -->
            <TextBlock Grid.Row="4" Text="Description (Optional)"
                       Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="DescriptionTextBox"
                     Grid.Row="5"
                     Style="{StaticResource FormTextBoxMultiline}"
                     Margin="0,0,0,20"/>

            <!-- Action buttons -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Create Task"
                        Width="120"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0"
                        Click="CreateButton_Click"
                        IsDefault="True"/>
                <Button Content="Cancel"
                        Width="90"
                        Style="{StaticResource MutedButton}"
                        Click="CancelButton_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
