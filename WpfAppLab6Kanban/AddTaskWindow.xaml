<Window x:Class="WpfAppLab6Kanban.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Task" Height="300" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="20" Background="#F9F9F9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Task Title" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox" Grid.Row="1" Margin="0,0,0,15" Padding="5" FontSize="14"/>

            <TextBlock Grid.Row="2" Text="Description (Optional)" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Row="3" Margin="0,0,0,15" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Create Task" Width="100" Height="30" Margin="0,0,10,0" Click="CreateButton_Click" IsDefault="True" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                <Button Content="Cancel" Width="80" Height="30" Click="CancelButton_Click" IsCancel="True" Background="#DDD" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
