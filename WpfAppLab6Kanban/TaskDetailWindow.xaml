<Window x:Class="WpfAppLab6Kanban.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Details" Height="630" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Status bar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock x:Name="StatusLabel"
                           Text="Status: TODO"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="ArchivedLabel"
                           Text="Archived: No"
                           FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>

            <!-- Title -->
            <TextBlock Grid.Row="1" Text="Title" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="TitleTextBox"
                     Grid.Row="2"
                     Style="{StaticResource FormTextBox}"/>

            <!-- Priority -->
            <TextBlock Grid.Row="3" Text="Priority" Style="{StaticResource FormLabel}"/>
            <ComboBox x:Name="PriorityComboBox"
                      Grid.Row="4"
                      Style="{StaticResource FormComboBox}">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <!-- Description -->
            <TextBlock Grid.Row="5" Text="Notes" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="DescriptionTextBox"
                     Grid.Row="6"
                     Style="{StaticResource FormTextBoxMultiline}"
                     Margin="0,0,0,20"/>

            <!-- Move Task -->
            <GroupBox x:Name="MoveGroupBox"
                      Grid.Row="7"
                      Header="Move Task"
                      Padding="10"
                      Margin="0,0,0,20"
                      Foreground="{StaticResource TextBrush}"
                      BorderBrush="{StaticResource BorderBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Each column button uses its own accent colour inline;
                         these are semantically distinct so they stay per-button -->
                    <Button x:Name="MoveTodoBtn" Content="TO DO"
                            Click="MoveTodo_Click"
                            Margin="5" Padding="15,8"
                            Background="#E8F0FE" Foreground="#2196F3"
                            FontWeight="Bold" BorderThickness="0"
                            Style="{StaticResource PrimaryButton}"
                            Height="Auto"/>
                    <Button x:Name="MoveProgressBtn" Content="PROGRESS"
                            Click="MoveProgress_Click"
                            Margin="5" Padding="15,8"
                            Background="#FFF4E5" Foreground="#FF9800"
                            FontWeight="Bold" BorderThickness="0"
                            Style="{StaticResource PrimaryButton}"
                            Height="Auto"/>
                    <Button x:Name="MoveDoneBtn" Content="DONE"
                            Click="MoveDone_Click"
                            Margin="5" Padding="15,8"
                            Background="#E6F4EA" Foreground="#4CAF50"
                            FontWeight="Bold" BorderThickness="0"
                            Style="{StaticResource PrimaryButton}"
                            Height="Auto"/>
                </StackPanel>
            </GroupBox>

            <Separator Grid.Row="9" Margin="0,10,0,15" Opacity="0.5"/>

            <!-- Footer: Delete | (spacer) | Save + Close -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="Delete Task"
                        Grid.Column="0"
                        Style="{StaticResource DangerButton}"
                        Padding="15,8" Height="Auto"
                        Click="DeleteButton_Click"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SaveButton"
                            Content="Save Changes"
                            IsEnabled="False"
                            Width="120"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0"
                            Click="SaveButton_Click"
                            IsDefault="True"/>
                    <Button Content="Close"
                            Width="90"
                            Style="{StaticResource MutedButton}"
                            Click="CancelButton_Click"
                            IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
