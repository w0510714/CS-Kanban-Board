<Window x:Class="WpfAppLab6Kanban.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Details" Height="650" Width="550" WindowStartupLocation="CenterOwner">
    <Border Padding="25" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Info -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock x:Name="StatusLabel" Text="Status: TODO" FontWeight="Bold" Foreground="#1A73E8" Margin="0,0,20,0"/>
                <TextBlock x:Name="ArchivedLabel" Text="Archived: No" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>

            <!-- Title -->
            <TextBlock Grid.Row="1" Text="Title" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox" Grid.Row="2" Margin="0,0,0,15" Padding="10" FontSize="14" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="#DDD"/>

            <!-- Priority -->
            <TextBlock Grid.Row="3" Text="Priority" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="PriorityComboBox" Grid.Row="4" Margin="0,0,0,15" Padding="5">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <!-- Description -->
            <TextBlock Grid.Row="5" Text="Notes" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Row="6" Margin="0,0,0,20" Height="150" TextWrapping="Wrap" AcceptsReturn="True" Padding="10" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="#DDD"/>

            <!-- Move Actions -->
            <GroupBox Grid.Row="7" Header="Move Task" Padding="10" Margin="0,0,0,20" x:Name="MoveGroupBox" Foreground="{DynamicResource TextBrush}" BorderBrush="#DDD">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="MoveTodoBtn" Content="TO DO" Click="MoveTodo_Click" Margin="5" Padding="15,8" Background="#E8F0FE" Foreground="#1A73E8" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style></Button.Resources>
                    </Button>
                    <Button x:Name="MoveProgressBtn" Content="PROGRESS" Click="MoveProgress_Click" Margin="5" Padding="15,8" Background="#FFF4E5" Foreground="#FF9800" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style></Button.Resources>
                    </Button>
                    <Button x:Name="MoveDoneBtn" Content="DONE" Click="MoveDone_Click" Margin="5" Padding="15,8" Background="#E6F4EA" Foreground="#4CAF50" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </GroupBox>

            <!-- Footer Buttons -->
            <Separator Grid.Row="9" Margin="0,20" Opacity="0.5"/>
            
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="Delete Task" Grid.Column="0" Click="DeleteButton_Click" Background="#FFF1F0" Foreground="#D93025" Padding="15,8" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style></Button.Resources>
                </Button>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SaveButton" Content="Save Changes" IsEnabled="False" Margin="0,0,10,0" Width="120" Height="35" Click="SaveButton_Click" IsDefault="True" Background="#1A73E8" Foreground="White" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="17"/></Style></Button.Resources>
                    </Button>
                    <Button Content="Close" Width="90" Height="35" Click="CancelButton_Click" IsCancel="True" Background="#DDD" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="17"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
