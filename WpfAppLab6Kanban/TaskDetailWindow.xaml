<Window x:Class="WpfAppLab6Kanban.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Details" Height="500" Width="450" WindowStartupLocation="CenterOwner">
    <Border Padding="20" Background="#F4F4F9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Info -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock x:Name="StatusLabel" Text="Status: TODO" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,20,0"/>
                <TextBlock x:Name="ArchivedLabel" Text="Archived: No" FontWeight="Bold" Foreground="#888"/>
            </StackPanel>

            <!-- Title -->
            <TextBlock Grid.Row="1" Text="Title" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox" Grid.Row="2" Margin="0,0,0,15" Padding="5"/>

            <!-- Priority -->
            <TextBlock Grid.Row="3" Text="Priority" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="PriorityComboBox" Grid.Row="4" Margin="0,0,0,15" Padding="5">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <!-- Description -->
            <TextBlock Grid.Row="5" Text="Notes" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Row="6" Margin="0,0,0,15" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>

            <!-- Move Actions -->
            <GroupBox Grid.Row="7" Header="Move Task" Margin="0,0,0,15" x:Name="MoveGroupBox">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button x:Name="MoveTodoBtn" Content="Move to TODO" Click="MoveTodo_Click" Margin="5" Padding="10,5"/>
                    <Button x:Name="MoveProgressBtn" Content="Move to IN PROGRESS" Click="MoveProgress_Click" Margin="5" Padding="10,5"/>
                    <Button x:Name="MoveDoneBtn" Content="Move to DONE" Click="MoveDone_Click" Margin="5" Padding="10,5"/>
                </StackPanel>
            </GroupBox>

            <!-- Footer Buttons -->
            <Separator Grid.Row="9" Margin="0,10"/>
            
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="Delete Task" Grid.Column="0" Click="DeleteButton_Click" Background="#FFEAEA" Foreground="#D32F2F" Padding="10,5" BorderThickness="1" BorderBrush="#FFCCD0"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SaveButton" Content="Save Changes" IsEnabled="False" Margin="0,0,10,0" Width="100" Click="SaveButton_Click" IsDefault="True" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                    <Button Content="Close" Width="80" Click="CancelButton_Click" IsCancel="True" Background="#DDD" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
