<Window x:Class="WpfAppLab6Kanban.ArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archived Tasks" Height="600" Width="800" WindowStartupLocation="CenterOwner">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,20">
            <TextBlock Text="Archived Tasks" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            <Button Content="Nuclear Clean" Click="DeleteAll_Click" HorizontalAlignment="Right" Padding="15,8" Background="#FFF1F0" Foreground="#D93025" FontWeight="Bold" BorderThickness="0">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style></Button.Resources>
            </Button>
        </DockPanel>

        <ListView x:Name="ArchiveListView" Grid.Row="1" ItemsSource="{Binding ArchivedTasks}" MouseDoubleClick="ArchiveListView_MouseDoubleClick" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="#DDD">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="180"/>
                    <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding Priority}" Width="90"/>
                    <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="250"/>
                    <GridViewColumn Header="Archived Date" DisplayMemberBinding="{Binding UpdatedAt}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Delete Item" Width="130" Height="35" Margin="0,0,10,0" Click="Delete_Click" Background="#FFF1F0" Foreground="#D93025" FontWeight="Bold" BorderThickness="0">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="17"/></Style></Button.Resources>
            </Button>
            <Button Content="Close" Width="90" Height="35" Click="Close_Click" Background="#DDD" BorderThickness="0">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="17"/></Style></Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
