<Window x:Class="WpfAppLab6Kanban.ArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Archived Tasks" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="25" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header row -->
            <DockPanel Margin="0,0,0,20">
                <TextBlock Text="Archived Tasks"
                           Style="{StaticResource DialogTitle}"
                           VerticalAlignment="Center"
                           Margin="0"/>
                <Button Content="Nuclear Clean"
                        HorizontalAlignment="Right"
                        Style="{StaticResource DangerButton}"
                        Padding="15,8" Height="Auto"
                        Click="DeleteAll_Click"/>
            </DockPanel>
            <ListView x:Name="ArchiveListView"
                      Grid.Row="1"
                      ItemsSource="{Binding ArchivedTasks}"
                      MouseDoubleClick="ArchiveListView_MouseDoubleClick"
                      Background="{DynamicResource CardBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Item">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Title"
                                        DisplayMemberBinding="{Binding Title}"
                                        Width="180"/>
                        <GridViewColumn Header="Priority"
                                        DisplayMemberBinding="{Binding Priority}"
                                        Width="90"/>
                        <GridViewColumn Header="Description"
                                        DisplayMemberBinding="{Binding Description}"
                                        Width="250"/>
                        <GridViewColumn Header="Archived Date"
                                        DisplayMemberBinding="{Binding UpdatedAt}"
                                        Width="150"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Footer buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Delete Item"
                        Width="130"
                        Style="{StaticResource DangerButton}"
                        Margin="0,0,10,0"
                        Click="Delete_Click"/>
                <Button Content="Close"
                        Width="90"
                        Style="{StaticResource MutedButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
